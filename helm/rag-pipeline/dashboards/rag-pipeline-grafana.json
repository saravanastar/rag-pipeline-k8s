{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel", "id": "gauge",      "name": "Gauge",      "version": "" },
    { "type": "panel", "id": "table",      "name": "Table",      "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "RAG Pipeline — end-to-end observability: Kafka lag, KEDA autoscaling, embedding throughput, Milvus latency, query p99.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "📊 Pipeline Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(crawler_pages_emitted_total[$__range])", "legendFormat": "Pages emitted" }],
      "title": "Pages Emitted (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(chunker_chunks_produced_total[$__range])", "legendFormat": "Chunks produced" }],
      "title": "Chunks Produced (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(embedding_chunks_embedded_total[$__range])", "legendFormat": "Chunks embedded" }],
      "title": "Chunks Embedded (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(query_api_requests_total{status=\"error\"}[5m]) / rate(query_api_requests_total[5m])",
        "legendFormat": "Error rate"
      }],
      "title": "Query Error Rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.99, rate(query_api_latency_seconds_bucket[5m]))",
        "legendFormat": "p99 latency"
      }],
      "title": "Query p99 Latency (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "embedding_throughput_chunks_per_sec", "legendFormat": "chunks/sec" }],
      "title": "Embedding Throughput",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "⚡ Kafka Consumer Lag & KEDA Autoscaling",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "chunker lag (page.crawled)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "embedding lag (chunk.ready)" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "chunker_kafka_consumer_lag",  "legendFormat": "chunker lag (page.crawled)" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "embedding_kafka_consumer_lag", "legendFormat": "embedding lag (chunk.ready)" }
      ],
      "title": "Kafka Consumer Lag",
      "description": "KEDA scales chunker when page.crawled lag > 5, embedding-service when chunk.ready lag > 10.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "stacking": { "mode": "none" } } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "kube_deployment_spec_replicas{deployment=\"chunker\"}",
          "legendFormat": "chunker — desired"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "kube_deployment_status_replicas_ready{deployment=\"chunker\"}",
          "legendFormat": "chunker — ready"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "kube_deployment_spec_replicas{deployment=\"embedding-service\"}",
          "legendFormat": "embedding-service — desired"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "kube_deployment_status_replicas_ready{deployment=\"embedding-service\"}",
          "legendFormat": "embedding-service — ready"
        }
      ],
      "title": "KEDA Replica Count (chunker + embedding-service)",
      "description": "Desired vs ready replicas. Scale-to-zero between crawl windows is expected.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "🕷️ Crawler",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(crawler_pages_crawled_total[10m])",  "legendFormat": "fetched (10m)" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(crawler_pages_emitted_total[10m])", "legendFormat": "emitted — new/changed (10m)" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(crawler_pages_skipped_total[10m])", "legendFormat": "skipped — unchanged (10m)" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "increase(crawler_pages_errored_total[10m])", "legendFormat": "errored (10m)" }
      ],
      "title": "Crawler Page Throughput (10m windows)",
      "description": "Emitted / total shows the incremental-diff efficiency. A high skip rate means few pages changed since the last crawl.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 15 },
      "id": 22,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "crawler_sitemap_urls_found", "legendFormat": "URLs in sitemap" }],
      "title": "Sitemap URLs Found",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] }, "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 15 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(crawler_pages_skipped_total[10m]) / rate(crawler_pages_crawled_total[10m])",
        "legendFormat": "skip ratio"
      }],
      "title": "Incremental Skip Ratio",
      "description": "High skip ratio = pipeline efficiency. Most pages unchanged between crawl runs.",
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "title": "✂️ Chunker",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 23 },
      "id": 31,
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(chunker_chunks_produced_total[1m])", "legendFormat": "chunks/sec" }],
      "title": "Chunker Output Rate (chunks/sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 23 },
      "id": 32,
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.50, rate(chunker_chunks_per_page_bucket[10m]))",
        "legendFormat": "p50 chunks/page"
      }, {
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, rate(chunker_chunks_per_page_bucket[10m]))",
        "legendFormat": "p95 chunks/page"
      }],
      "title": "Chunks per Page (p50 / p95)",
      "description": "Tells you how long the average doc is. A spike in p95 indicates very long pages that produce many chunks.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 23 },
      "id": 33,
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.50, rate(chunker_chunk_size_tokens_bucket[10m]))",
        "legendFormat": "p50 tokens"
      }, {
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.95, rate(chunker_chunk_size_tokens_bucket[10m]))",
        "legendFormat": "p95 tokens"
      }],
      "title": "Chunk Size Distribution (tokens)",
      "description": "Chunks should cluster near 512 tokens. A low p50 indicates many short pages producing under-sized chunks.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 40,
      "title": "🧠 Embedding Service",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 31 },
      "id": 41,
      "targets": [{ "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "embedding_throughput_chunks_per_sec", "legendFormat": "chunks/sec (60s rolling)" }],
      "title": "Embedding Throughput (chunks/sec)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 31 },
      "id": 42,
      "targets": [
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(embedding_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "inference p50"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(embedding_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "inference p99"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(embedding_milvus_insert_latency_seconds_bucket[5m]))",
          "legendFormat": "milvus insert p99"
        }
      ],
      "title": "Embedding Latency (inference + Milvus insert)",
      "description": "inference p99 > 100ms or milvus insert p99 > 1s will trigger PrometheusRule alerts.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 31 },
      "id": 43,
      "targets": [
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(embedding_batch_size_bucket[5m]))",
          "legendFormat": "batch size p50"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(embedding_errors_total[5m])",
          "legendFormat": "errors/sec — {{reason}}"
        }
      ],
      "title": "Embedding Batch Size & Errors",
      "description": "Batch size should be near EMBED_BATCH_SIZE (32). Smaller batches mean the 2s timeout flush is firing — topic lag is low.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 50,
      "title": "🔍 Query API",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 39 },
      "id": 51,
      "targets": [
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(query_api_requests_total{status=\"success\"}[1m])", "legendFormat": "success" },
        { "datasource": { "uid": "${DS_PROMETHEUS}" }, "expr": "rate(query_api_requests_total{status=\"error\"}[1m])",   "legendFormat": "error" }
      ],
      "title": "Query API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 39 },
      "id": 52,
      "targets": [
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(query_api_latency_seconds_bucket[5m]))",
          "legendFormat": "end-to-end p50"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(query_api_latency_seconds_bucket[5m]))",
          "legendFormat": "end-to-end p99"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(query_api_embed_call_latency_seconds_bucket[5m]))",
          "legendFormat": "embed call p99"
        },
        {
          "datasource": { "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(query_api_milvus_search_latency_seconds_bucket[5m]))",
          "legendFormat": "milvus search p99"
        }
      ],
      "title": "Query Latency Breakdown",
      "description": "end-to-end = embed call + Milvus search + serialization. Target: p99 < 50ms.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 0.2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.02 }, { "color": "red", "value": 0.05 }] } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 39 },
      "id": 53,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(query_api_requests_total{status=\"error\"}[5m]) / rate(query_api_requests_total[5m])",
        "legendFormat": "error rate"
      }],
      "title": "Query Error Rate",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 39 },
      "id": 54,
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "histogram_quantile(0.99, rate(embedding_api_latency_seconds_bucket[5m]))",
        "legendFormat": "embed endpoint p99"
      }],
      "title": "Embedding Service /embed Latency (p99)",
      "description": "Latency as seen by the query-api's HTTP call. Spike here = model under load, not Milvus.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "id": 60,
      "title": "📨 Kafka Broker",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 47 },
      "id": 61,
      "targets": [{
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "expr": "kafka_topic_messages_in_per_sec",
        "legendFormat": "{{topic}}"
      }],
      "title": "Kafka Messages In/sec by Topic",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
